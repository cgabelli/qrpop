generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id              String     @id @default(cuid())
  businessName    String     // Per i privati sarà "Nome Cognome", per le aziende la "Ragione Sociale"
  slug            String     @unique
  email           String     @unique
  password        String
  
  // KYC Dati
  isCompany       Boolean    @default(false)
  firstName       String?
  lastName        String?
  address         String?
  city            String?
  province        String?
  zipCode         String?
  fiscalCode      String?
  vatNumber       String?
  sdiCode         String?
  phone           String?
  
  // Verifica
  emailVerified    DateTime?
  verificationToken String?   @unique

  plan            String     @default("basic_image")
  billingInterval String     @default("monthly")
  isActive        Boolean    @default(true)
  baseCredits     Int        @default(0)
  purchasedCredits Int       @default(0)
  uploadResetDate DateTime   @default(now())
  
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  accounts     Account[]
  sessions     Session[]
  creativita   Creativita[]
}

model Creativita {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String    // 'image' | 'video'
  filePath      String
  thumbnailPath String?
  publishAt     DateTime?
  expiresAt     DateTime?
  status        String    @default("draft") // 'draft' | 'scheduled' | 'active' | 'expired'
  fileName      String
  fileSize      Int
  title         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
